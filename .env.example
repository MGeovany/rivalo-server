# Copy to .env and fill in. The server reads these at startup.

# HTTP port (optional, defaults to 8080)
PORT=8080

# Log level: debug, info, warn, error (optional, defaults to info)
LOG_LEVEL=info

# PostgreSQL connection string from Supabase (Project Settings > Database).
# Use the SESSION pooler (port 5432), not the transaction pooler (6543): session
# mode supports prepared statements (needed by pgx) and is required by Atlas
# migrations. Leave empty to run without a database (health endpoint still works).
# Example: postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase project base URL. When set, JWTs are validated against the project's
# JWKS (asymmetric ES256 keys, the Supabase default). Preferred over the secret.
SUPABASE_URL=https://<ref>.supabase.co

# Legacy HS256 shared secret, used only as a fallback when SUPABASE_URL is unset.
SUPABASE_JWT_SECRET=

# Service role key (Project Settings > API). Required for `make seed` only — never
# ship this in the mobile app.
SUPABASE_SERVICE_ROLE_KEY=
